{
  "name": "archived",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "predev:worker": "mkdir -p dist",
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:create": "wrangler d1 create archived",
    "db:migrate:local": "wrangler d1 migrations apply archived --local",
    "db:migrate:remote": "wrangler d1 migrations apply archived --remote",
    "db:migrations:list": "wrangler d1 migrations list archived",
    "r2:create": "wrangler r2 bucket create archived-images",
    "import:gzallen-tweets": "node scripts/import-gzallen-twitter.mjs",
    "import:zym-tweets": "node scripts/import-zym-tweets.mjs",
    "import:wangxing-tweets": "node scripts/import-wangxing-tweets.mjs",
    "db:normalize-datetime": "node scripts/normalize-datetime-text.mjs",
    "db:normalize-datetime:dry": "node scripts/normalize-datetime-text.mjs --dry-run"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "antd": "^6.3.7",
    "hono": "^4.6.13",
    "p-limit": "^7.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.20.0",
    "sharp": "^0.34.5",
    "stream-chain": "^3.6.1",
    "stream-json": "^2.1.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@eslint/js": "^9.30.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "csv-parse": "^5.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "wrangler": "^4.87.0"
  }
}
